# Your Anthropic API key. Get one at https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-...

# Port the Express API listens on (default 3001).
PORT=3001

# Model to use. Defaults to claude-sonnet-4-6 if unset.
# Cheaper option: claude-haiku-4-5
MODEL=claude-sonnet-4-6

# --- Rate limiting (protects your key on public deploys) ---
# Max requests per IP per window, and window length in milliseconds.
RATE_LIMIT_MAX=30
RATE_LIMIT_WINDOW_MS=300000

# Set to 1 (or the number of proxy hops) ONLY if deployed behind a reverse
# proxy / load balancer, so rate limiting sees the real client IP.
# TRUST_PROXY=1
